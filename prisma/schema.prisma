generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPANY_OWNER
  EDITOR
  VIEWER
}

enum TicketStatus {
  YENI
  INCELENIYOR
  CEVAPLANDI
  COZULDU
}

enum TicketPriority {
  DUSUK
  ORTA
  KRITIK
}

enum TicketType {
  BUG
  ONERI
}

enum PortalCustomerType {
  CUSTOMER
  SUBCONTRACTOR
}

enum SubcontractorOrderStatus {
  PENDING
  MATERIAL_SENT
  IN_PRODUCTION
  IN_PROGRESS
  COMPLETED
  RECEIVED
  CANCELLED
}

enum TransferDirection {
  OUTGOING
  INCOMING
}

enum SubscriptionStatus {
  FREE
  TRIAL
  PRO
}

enum CompanyType {
  SOLE_MANUFACTURER
  MATERIAL_SUPPLIER
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  address            String?
  taxId              String?
  phone              String?
  bankInfo           String?
  logoUrl            String?
  usdToTry           Float              @default(1)
  eurToTry           Float              @default(1)
  vatRate            Float              @default(20)
  companyType        CompanyType        @default(SOLE_MANUFACTURER)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  auditLogs          AuditLog[]
  employees          Employee[]
  personnelDocuments PersonnelDocument[]
  materials          Material[]
  soleCalculations   SoleCalculation[]
  customers          Customer[]
  suppliers          Supplier[]
  invoices           Invoice[]
  purchases          Purchase[]
  payments           Payment[]
  products           Product[]
  accounts           Account[]
  cekler             Cek[]
  soleOrders            SoleOrder[]
  subcontractors        Subcontractor[]
  subcontractorOrders   SubcontractorOrder[]
  materialTransfers     MaterialTransfer[]
  subcontractorScraps   SubcontractorScrap[]
  stockAdjustments      StockAdjustment[]
  productCategories     ProductCategory[]
  customerProductPrices CustomerProductPrice[]
  materialCalculations  MaterialCalculation[]
  supportTickets        SupportTicket[]
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  password         String
  role             Role             @default(EDITOR)
  language         String           @default("tr")
  currency         String           @default("USD")
  allowedPages     String[]         @default([])
  resetToken             String?          @unique
  resetTokenExpiry       DateTime?
  emailVerified          Boolean          @default(false)
  emailVerifyToken       String?          @unique
  impersonateToken       String?          @unique
  impersonateTokenExpiry DateTime?
  companyId              String?
  company          Company?         @relation(fields: [companyId], references: [id])
  soleCalculations SoleCalculation[]
  invoices         Invoice[]
  auditLogs        AuditLog[]
  supportTickets   SupportTicket[]  @relation("ticketCreator")
  ticketMessages   TicketMessage[]  @relation("messageAuthor")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Material {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  name              String
  category          String?
  supplier          String?
  pricePerKg        Float
  currency          String             @default("USD")
  description       String?
  stock             Float              @default(0)
  soleParts         SolePart[]
  productParts      ProductPart[]
  priceHistory      PriceHistory[]
  purchaseMaterials   PurchaseMaterial[]
  subcontractorStocks SubcontractorStock[]
  materialTransfers   MaterialTransfer[]
  subcontractorScraps SubcontractorScrap[]
  stockAdjustments    StockAdjustment[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model PriceHistory {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  pricePerKg Float
  currency   String
  createdAt  DateTime @default(now())
}

model SoleCalculation {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  name         String
  parts        SolePart[]
  laborMethod         String   @default("direct")
  laborCurrency       String   @default("USD")
  monthlySalary       Float?
  workDays            Int?
  dailyProduction     Int?
  laborCostPerPair    Float    @default(0)
  paintCost           Float    @default(0)
  profitMargin        Float    @default(0)
  vatRate             Float    @default(0)
  totalMaterialCost   Float    @default(0)
  totalCost           Float    @default(0)
  sellingPrice        Float    @default(0)
  sellingPriceWithVat Float    @default(0)
  currency            String   @default("USD")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum OrderStatus {
  ORDER_RECEIVED
  IN_PRODUCTION
  MOLDING
  PAINTING
  PACKAGING
  READY_FOR_SHIPMENT
  SHIPPED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentType {
  RECEIVED
  PAID
}

model Product {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id])
  code             String?
  name             String
  description      String?
  unit             String             @default("çift")
  unitPrice        Float              @default(0)
  currency         String             @default("USD")
  stock            Float              @default(0)
  notes            String?
  sizes            String[]           @default([])
  laborCostPerPair Float              @default(0)
  laborCurrency    String             @default("USD")
  ciftPerKoli      Float              @default(0)
  koliFiyati       Float              @default(0)
  koliCurrency     String             @default("USD")
  portalVisible    Boolean            @default(false)
  categoryId       String?
  category         ProductCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parts               ProductPart[]
  extraCosts          ProductExtraCost[]
  invoiceItems        InvoiceItem[]
  soleOrders          SoleOrder[]
  portalCustomers     ProductPortalCustomer[]
  subcontractorOrders   SubcontractorOrder[]
  customerProductPrices CustomerProductPrice[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model ProductPart {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId    String?
  material      Material? @relation(fields: [materialId], references: [id])
  name          String
  gramsPerPiece Float     @default(0)
  wasteRate     Float     @default(0)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductExtraCost {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  amount    Float    @default(0)
  currency  String   @default("USD")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  name       String
  taxId      String?
  taxOffice  String?
  email      String?
  phone      String?
  address    String?
  currency   String    @default("TRY")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  invoices              Invoice[]
  payments              Payment[]
  cekler                Cek[]
  portalCustomer        PortalCustomer?
  soleOrders            SoleOrder[]
  customerProductPrices CustomerProductPrice[]
}

model Supplier {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  name      String
  taxId     String?
  email     String?
  phone     String?
  address   String?
  currency  String     @default("USD")
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  payments  Payment[]
  cekler    Cek[]
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  invoiceNo      String
  date           DateTime
  dueDate        DateTime?
  currency       String        @default("USD")
  subtotal       Float         @default(0)
  vatRate        Float         @default(0)
  vatAmount      Float         @default(0)
  total          Float         @default(0)
  paidAmount     Float         @default(0)
  status         InvoiceStatus @default(PENDING)
  isReturn       Boolean       @default(false)
  stockDeducted  Boolean       @default(false)
  notes          String?
  createdById    String?
  createdBy      User?         @relation(fields: [createdById], references: [id])
  items          InvoiceItem[]
  payments       Payment[]
  soleOrder      SoleOrder?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([companyId, invoiceNo])
}

model InvoiceItem {
  id               String   @id @default(cuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product? @relation(fields: [productId], references: [id])
  description      String
  quantity         Float
  unitPrice        Float
  discount         Float    @default(0)
  total            Float
  notes            String?
  partVariantsData Json?    // [{ partId, variantId }] - sale-time variant selections
}

model Purchase {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  supplierId        String
  supplier          Supplier           @relation(fields: [supplierId], references: [id])
  invoiceNo         String?
  date              DateTime
  currency          String             @default("USD")
  total             Float              @default(0)
  paidAmount        Float              @default(0)
  status            InvoiceStatus      @default(PENDING)
  notes             String?
  payments          Payment[]
  purchaseMaterials PurchaseMaterial[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([companyId, invoiceNo])
}

model PurchaseMaterial {
  id            String         @id @default(cuid())
  purchaseId    String
  purchase      Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  materialId    String
  material      Material       @relation(fields: [materialId], references: [id])
  kgAmount      Float          @default(0)
  pricePerKg    Float?
  subcontractorId String?
  subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id])
  createdAt     DateTime       @default(now())
}

model Payment {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  type             PaymentType
  customerId       String?
  customer         Customer?   @relation(fields: [customerId], references: [id])
  supplierId       String?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])
  invoiceId        String?
  invoice          Invoice?    @relation(fields: [invoiceId], references: [id])
  purchaseId       String?
  purchase         Purchase?   @relation(fields: [purchaseId], references: [id])
  accountId        String?
  account          Account?    @relation(fields: [accountId], references: [id])
  amount           Float
  currency         String      @default("TRY")
  originalAmount   Float?
  originalCurrency String?
  exchangeRate     Float?
  date             DateTime
  method           String      @default("Nakit")
  notes            String?
  createdAt        DateTime    @default(now())
}

model Account {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  type      String    @default("Kasa")
  currency  String    @default("TRY")
  balance   Float     @default(0)
  color     String    @default("#3B82F6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
}

model SolePart {
  id            String          @id @default(cuid())
  calculationId String
  calculation   SoleCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  materialId    String
  material      Material        @relation(fields: [materialId], references: [id])
  partName      String
  grossWeight   Float
  wasteRate     Float           @default(0)
  netWeight     Float
  cost          Float
  createdAt     DateTime        @default(now())
}

enum CekDurum {
  PORTFOY
  BANKAYA_VERILDI
  TEDARIKCI_VERILDI
  ODENDI
  KARSILIKS
  IPTAL
}

model Cek {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  borclu      String
  islem       String    @default("Müşteriden Alınan Çek Kaydı")
  aciklama    String?
  islemTarihi DateTime  @default(now())
  vadesi      DateTime
  tutar           Float
  currency        String    @default("TRY")
  customerAmount  Float?    // Müşteri para birimindeki karşılık (çapraz dövizde doldurulur)
  customerCurrency String?  // Müşteri para birimi
  seriNo      String?
  bankasi     String?
  durum       CekDurum  @default(PORTFOY)
  paymentId   String?   // linked Payment.id when check is collected (ODENDI)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── B2B Customer Portal ───────────────────────────────────────────────────

model PortalCustomer {
  id               String             @id @default(cuid())
  customerId       String?            @unique
  customer         Customer?          @relation(fields: [customerId], references: [id])
  portalType       PortalCustomerType @default(CUSTOMER)
  email            String             @unique
  password         String
  name             String?
  emailVerified    Boolean            @default(false)
  emailVerifyToken String?            @unique
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  orders           SoleOrder[]
  productVisibility ProductPortalCustomer[]
  subcontractor    Subcontractor?     @relation("PortalCustomerSubcontractor")
}

model ProductPortalCustomer {
  id               String         @id @default(cuid())
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  portalCustomerId String
  portalCustomer   PortalCustomer @relation(fields: [portalCustomerId], references: [id], onDelete: Cascade)

  @@unique([productId, portalCustomerId])
}

model SoleOrder {
  id                    String               @id @default(cuid())
  companyId             String
  company               Company              @relation(fields: [companyId], references: [id])
  customerId            String
  customer              Customer             @relation(fields: [customerId], references: [id])
  portalCustomerId      String?
  portalCustomer        PortalCustomer?      @relation(fields: [portalCustomerId], references: [id])
  orderNo               String
  productId             String?
  product               Product?             @relation(fields: [productId], references: [id])
  productCode           String?
  color                 String?
  material              String?
  sizeDistribution      Json
  totalQuantity         Int
  requestedDeliveryDate DateTime?
  confirmedDeliveryDate DateTime?
  notes                 String?
  colorPartials         Json?
  orderItems            Json?
  partVariantsData      Json?
  invoiceId             String?              @unique
  invoice               Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  convertedAt           DateTime?
  status                OrderStatus          @default(ORDER_RECEIVED)
  statusHistory         OrderStatusHistory[]
  shipment              OrderShipment?
  subcontractorOrders   SubcontractorOrder[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([companyId, orderNo])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     SoleOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

model OrderShipment {
  id             String    @id @default(cuid())
  orderId        String    @unique
  order          SoleOrder @relation(fields: [orderId], references: [id])
  shipmentDate   DateTime
  deliveryNoteNo String?
  trackingNo     String?
  carrier        String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Fason Modülleri ───────────────────────────────────────────────────────────

model Subcontractor {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  name            String
  contactPerson   String?
  phone           String?
  address         String?
  email           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  materialStocks      SubcontractorStock[]
  purchaseMaterials   PurchaseMaterial[]
  subcontractorOrders SubcontractorOrder[]
  materialTransfers   MaterialTransfer[]
  stockAdjustments    StockAdjustment[]
  portalCustomer      PortalCustomer?      @relation("PortalCustomerSubcontractor", fields: [portalCustomerId], references: [id])
  portalCustomerId    String?              @unique

  @@index([companyId])
}

model SubcontractorOrder {
  id                String                   @id @default(cuid())
  companyId         String
  company           Company                  @relation(fields: [companyId], references: [id])
  orderNo           String
  subcontractorId   String
  subcontractor     Subcontractor            @relation(fields: [subcontractorId], references: [id])
  productId         String?
  product           Product?                 @relation(fields: [productId], references: [id])
  soleOrderId       String?
  soleOrder         SoleOrder?               @relation(fields: [soleOrderId], references: [id])
  sizeDistribution  Json
  totalPairs        Int                      @default(0)
  dueDate           DateTime?
  status            SubcontractorOrderStatus @default(PENDING)
  notes             String?
  shippingAddress   String?
  emailSentAt       DateTime?
  materialTransfers MaterialTransfer[]
  productionUpdates ProductionUpdate[]
  scraps            SubcontractorScrap[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([companyId, orderNo])
  @@index([companyId])
  @@index([subcontractorId])
}

model StockAdjustment {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  materialId      String
  material        Material       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  subcontractorId String?
  subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id])
  delta           Float
  type            String         // 'artirma' | 'azaltma' | 'stok_guncelleme'
  notes           String?
  createdAt       DateTime       @default(now())

  @@index([materialId])
  @@index([companyId])
  @@index([subcontractorId])
}

model MaterialTransfer {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  subcontractorId String
  subcontractor   Subcontractor       @relation(fields: [subcontractorId], references: [id])
  orderId         String?
  order           SubcontractorOrder? @relation(fields: [orderId], references: [id])
  materialId      String
  material        Material            @relation(fields: [materialId], references: [id])
  quantity        Float
  direction       TransferDirection
  transferDate    DateTime            @default(now())
  notes           String?
  createdAt       DateTime            @default(now())

  @@index([companyId])
  @@index([subcontractorId])
  @@index([orderId])
}

model ProductionUpdate {
  id             String                   @id @default(cuid())
  orderId        String
  order          SubcontractorOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         SubcontractorOrderStatus
  completedPairs Int?
  notes          String?
  updatedBy      String?
  createdAt      DateTime                 @default(now())

  @@index([orderId])
}

model SubcontractorScrap {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id])
  orderId     String
  order       SubcontractorOrder @relation(fields: [orderId], references: [id])
  materialId  String
  material    Material           @relation(fields: [materialId], references: [id])
  quantity    Float
  reason      String?
  reportedBy  String?
  createdAt   DateTime           @default(now())

  @@index([orderId])
  @@index([companyId])
}

// ─── Ürün Kategorileri ────────────────────────────────────────────────────────

model ProductCategory {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  createdAt DateTime  @default(now())
  products  Product[]

  @@unique([companyId, name])
  @@index([companyId])
}

// ─── Müşteri Özel Fiyatlandırma ──────────────────────────────────────────────

model CustomerProductPrice {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitPrice  Float
  currency   String   @default("TRY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId])
  @@index([companyId])
  @@index([customerId])
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  userName  String?
  action    String   // CREATE | UPDATE | DELETE | ERROR
  entity    String   // Invoice | Payment | Cek | Customer | Supplier | Material | Stock
  entityId  String?
  detail    String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}

// ─── Personel Takip ──────────────────────────────────────────────────────────

model Employee {
  id              String            @id @default(cuid())
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id])
  name            String
  department      String
  role            String
  salary          Float             @default(0)
  currency        String            @default("TRY")
  status          String            @default("active") // active | left
  hireDate        DateTime
  payday          Int               @default(1)
  leaveBalance    Float             @default(14)
  phone           String?
  email           String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ledger          PersonnelLedger[]
  documents       PersonnelDocument[]
  leaves          PersonnelLeave[]
  overtimes       PersonnelOvertime[]
  personnelNotes  PersonnelNote[]

  @@index([companyId])
}

model PersonnelLedger {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  type        String   // Maaş | Avans | Hakediş | Prim | Kesinti | İzin | Mesai | Diğer
  description String?
  debit       Float    @default(0)
  credit      Float    @default(0)
  account     String?
  paymentId   String?  // linked Payment.id for kasa integration
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model PersonnelLeave {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  type        String   // Yıllık | Mazeret | Ücretsiz | Hastalık
  days        Float
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
}

model PersonnelOvertime {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Float
  amount      Float    @default(0)
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
}

model PersonnelNote {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  content     String
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
}

model PersonnelDocument {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name        String
  docType     String
  size        Int
  mimeType    String
  data        Bytes
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

// Fasoncu deposundaki anlık hammadde zimmet durumu
model SubcontractorStock {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id])
  materialId      String
  material        Material      @relation(fields: [materialId], references: [id])
  quantity        Float         @default(0)
  updatedAt       DateTime      @updatedAt

  @@unique([subcontractorId, materialId])
  @@index([subcontractorId])
}

// ─── Hammaddeci Maliyet Hesaplayıcısı ────────────────────────────────────────

model MaterialCalculation {
  id         String                    @id @default(cuid())
  companyId  String
  company    Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  notes      String?
  kurUsd     Float                     @default(0)
  kurEur     Float                     @default(0)
  kdvRate    Float                     @default(0.20)
  laborPerKg Float                     @default(0)
  laborCur   String                    @default("TRY")
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  items      MaterialCalculationItem[]

  @@index([companyId])
}

model MaterialCalculationItem {
  id             String              @id @default(cuid())
  calculationId  String
  calculation    MaterialCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  name           String
  qty            Float               @default(0)
  currency       String              @default("TRY")
  unitPriceExVat Float               @default(0)
  sortOrder      Int                 @default(0)

  @@index([calculationId])
}

// ─── Destek Merkezi ────────────────────────────────────────────────────────────

model SupportTicket {
  id          String           @id @default(cuid())
  ticketNo    String
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id], name: "ticketCreator")
  type        TicketType       @default(BUG)
  title       String
  description String
  module      String?
  priority    TicketPriority   @default(ORTA)
  status      TicketStatus     @default(YENI)
  pageUrl     String?
  browser     String?
  messages    TicketMessage[]
  attachments TicketAttachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?

  @@unique([companyId, ticketNo])
  @@index([companyId])
  @@index([status])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], name: "messageAuthor")
  isAdmin   Boolean       @default(false)
  content   String
  createdAt DateTime      @default(now())
}

model TicketAttachment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  name      String
  size      Int
  mimeType  String
  data      Bytes
  createdAt DateTime      @default(now())
}
