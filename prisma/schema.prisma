generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPANY_OWNER
  EDITOR
  VIEWER
}

enum SubscriptionStatus {
  FREE
  TRIAL
  PRO
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  address            String?
  taxId              String?
  phone              String?
  bankInfo           String?
  logoUrl            String?
  usdToTry           Float              @default(1)
  eurToTry           Float              @default(1)
  vatRate            Float              @default(20)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  materials          Material[]
  soleCalculations   SoleCalculation[]
  customers          Customer[]
  suppliers          Supplier[]
  invoices           Invoice[]
  purchases          Purchase[]
  payments           Payment[]
  products           Product[]
  accounts           Account[]
  cekler             Cek[]
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  password         String
  role             Role             @default(EDITOR)
  language         String           @default("tr")
  currency         String           @default("USD")
  allowedPages     String[]         @default([])
  resetToken       String?          @unique
  resetTokenExpiry DateTime?
  companyId        String?
  company          Company?         @relation(fields: [companyId], references: [id])
  soleCalculations SoleCalculation[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Material {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  name              String
  supplier          String?
  pricePerKg        Float
  currency          String             @default("USD")
  description       String?
  stock             Float              @default(0)
  soleParts         SolePart[]
  productParts      ProductPart[]
  priceHistory      PriceHistory[]
  purchaseMaterials PurchaseMaterial[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PriceHistory {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  pricePerKg Float
  currency   String
  createdAt  DateTime @default(now())
}

model SoleCalculation {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  name         String
  parts        SolePart[]
  laborMethod         String   @default("direct")
  laborCurrency       String   @default("USD")
  monthlySalary       Float?
  workDays            Int?
  dailyProduction     Int?
  laborCostPerPair    Float    @default(0)
  paintCost           Float    @default(0)
  profitMargin        Float    @default(0)
  vatRate             Float    @default(0)
  totalMaterialCost   Float    @default(0)
  totalCost           Float    @default(0)
  sellingPrice        Float    @default(0)
  sellingPriceWithVat Float    @default(0)
  currency            String   @default("USD")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentType {
  RECEIVED
  PAID
}

model Product {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id])
  code             String?
  name             String
  description      String?
  unit             String             @default("çift")
  unitPrice        Float              @default(0)
  currency         String             @default("USD")
  stock            Float              @default(0)
  notes            String?
  sizes            String[]           @default([])
  laborCostPerPair Float              @default(0)
  laborCurrency    String             @default("USD")
  ciftPerKoli      Float              @default(0)
  koliFiyati       Float              @default(0)
  koliCurrency     String             @default("USD")
  parts            ProductPart[]
  extraCosts       ProductExtraCost[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model ProductPart {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialId    String?
  material      Material? @relation(fields: [materialId], references: [id])
  name          String
  gramsPerPiece Float     @default(0)
  wasteRate     Float     @default(0)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ProductExtraCost {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  amount    Float    @default(0)
  currency  String   @default("USD")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  name       String
  taxId      String?
  taxOffice  String?
  email      String?
  phone      String?
  address    String?
  currency   String    @default("TRY")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  invoices   Invoice[]
  payments   Payment[]
  cekler     Cek[]
}

model Supplier {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  name      String
  taxId     String?
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  payments  Payment[]
  cekler    Cek[]
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  invoiceNo      String
  date           DateTime
  dueDate        DateTime?
  currency       String        @default("USD")
  subtotal       Float         @default(0)
  vatRate        Float         @default(0)
  vatAmount      Float         @default(0)
  total          Float         @default(0)
  paidAmount     Float         @default(0)
  status         InvoiceStatus @default(PENDING)
  isReturn       Boolean       @default(false)
  stockDeducted  Boolean       @default(false)
  notes          String?
  items          InvoiceItem[]
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Float
  unitPrice   Float
  discount    Float    @default(0)
  total       Float
  notes       String?
}

model Purchase {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id])
  supplierId        String
  supplier          Supplier           @relation(fields: [supplierId], references: [id])
  invoiceNo         String?
  date              DateTime
  currency          String             @default("USD")
  total             Float              @default(0)
  paidAmount        Float              @default(0)
  status            InvoiceStatus      @default(PENDING)
  notes             String?
  payments          Payment[]
  purchaseMaterials PurchaseMaterial[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PurchaseMaterial {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  kgAmount   Float    @default(0)
  pricePerKg Float?
  createdAt  DateTime @default(now())
}

model Payment {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  type             PaymentType
  customerId       String?
  customer         Customer?   @relation(fields: [customerId], references: [id])
  supplierId       String?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])
  invoiceId        String?
  invoice          Invoice?    @relation(fields: [invoiceId], references: [id])
  purchaseId       String?
  purchase         Purchase?   @relation(fields: [purchaseId], references: [id])
  accountId        String?
  account          Account?    @relation(fields: [accountId], references: [id])
  amount           Float
  currency         String      @default("TRY")
  originalAmount   Float?
  originalCurrency String?
  exchangeRate     Float?
  date             DateTime
  method           String      @default("Nakit")
  notes            String?
  createdAt        DateTime    @default(now())
}

model Account {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  type      String    @default("Kasa")
  currency  String    @default("TRY")
  balance   Float     @default(0)
  color     String    @default("#3B82F6")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
}

model SolePart {
  id            String          @id @default(cuid())
  calculationId String
  calculation   SoleCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  materialId    String
  material      Material        @relation(fields: [materialId], references: [id])
  partName      String
  grossWeight   Float
  wasteRate     Float           @default(0)
  netWeight     Float
  cost          Float
  createdAt     DateTime        @default(now())
}

enum CekDurum {
  PORTFOY
  BANKAYA_VERILDI
  TEDARIKCI_VERILDI
  ODENDI
  KARSILIKS
  IPTAL
}

model Cek {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  borclu      String
  islem       String    @default("Müşteriden Alınan Çek Kaydı")
  aciklama    String?
  islemTarihi DateTime  @default(now())
  vadesi      DateTime
  tutar       Float
  currency    String    @default("TRY")
  seriNo      String?
  bankasi     String?
  durum       CekDurum  @default(PORTFOY)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
