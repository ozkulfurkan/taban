generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  COMPANY_OWNER
  EDITOR
  VIEWER
}

enum SubscriptionStatus {
  FREE
  TRIAL
  PRO
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  address            String?
  taxId              String?
  phone              String?
  bankInfo           String?
  logoUrl            String?
  usdToTry           Float              @default(1)
  eurToTry           Float              @default(1)
  vatRate            Float              @default(20)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              User[]
  materials          Material[]
  soleCalculations   SoleCalculation[]
  customers          Customer[]
  suppliers          Supplier[]
  invoices           Invoice[]
  purchases          Purchase[]
  payments           Payment[]
  products           Product[]
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  password         String
  role             Role             @default(EDITOR)
  language         String           @default("tr")
  currency         String           @default("USD")
  companyId        String?
  company          Company?         @relation(fields: [companyId], references: [id])
  soleCalculations SoleCalculation[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Material {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  name        String
  supplier    String?
  pricePerKg  Float
  currency    String         @default("USD")
  description String?
  soleParts   SolePart[]
  priceHistory PriceHistory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PriceHistory {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  pricePerKg Float
  currency   String
  createdAt  DateTime @default(now())
}

model SoleCalculation {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  name         String
  parts        SolePart[]
  laborMethod         String   @default("direct")
  laborCurrency       String   @default("USD")
  monthlySalary       Float?
  workDays            Int?
  dailyProduction     Int?
  laborCostPerPair    Float    @default(0)
  paintCost           Float    @default(0)
  profitMargin        Float    @default(0)
  vatRate             Float    @default(0)
  totalMaterialCost   Float    @default(0)
  totalCost           Float    @default(0)
  sellingPrice        Float    @default(0)
  sellingPriceWithVat Float    @default(0)
  currency            String   @default("USD")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentType {
  RECEIVED
  PAID
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  code        String?
  name        String
  description String?
  unit        String   @default("çift")
  unitPrice   Float    @default(0)
  currency    String   @default("USD")
  stock       Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  name       String
  taxId      String?
  taxOffice  String?
  email      String?
  phone      String?
  address    String?
  currency   String    @default("TRY")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  invoices   Invoice[]
  payments   Payment[]
}

model Supplier {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  name      String
  taxId     String?
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  payments  Payment[]
}

model Invoice {
  id         String        @id @default(cuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  invoiceNo  String
  date       DateTime
  dueDate    DateTime?
  currency   String        @default("USD")
  subtotal   Float         @default(0)
  vatRate    Float         @default(0)
  vatAmount  Float         @default(0)
  total      Float         @default(0)
  paidAmount Float         @default(0)
  status     InvoiceStatus @default(PENDING)
  notes      String?
  items      InvoiceItem[]
  payments   Payment[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  total       Float
  notes       String?
}

model Purchase {
  id         String        @id @default(cuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  supplierId String
  supplier   Supplier      @relation(fields: [supplierId], references: [id])
  invoiceNo  String?
  date       DateTime
  currency   String        @default("USD")
  total      Float         @default(0)
  paidAmount Float         @default(0)
  status     InvoiceStatus @default(PENDING)
  notes      String?
  payments   Payment[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Payment {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  type       PaymentType
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id])
  supplierId String?
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  invoiceId  String?
  invoice    Invoice?    @relation(fields: [invoiceId], references: [id])
  purchaseId String?
  purchase   Purchase?   @relation(fields: [purchaseId], references: [id])
  amount     Float
  currency   String      @default("USD")
  date       DateTime
  method     String      @default("Nakit")
  notes      String?
  createdAt  DateTime    @default(now())
}

model SolePart {
  id            String          @id @default(cuid())
  calculationId String
  calculation   SoleCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  materialId    String
  material      Material        @relation(fields: [materialId], references: [id])
  partName      String
  grossWeight   Float
  wasteRate     Float           @default(0)
  netWeight     Float
  cost          Float
  createdAt     DateTime        @default(now())
}
