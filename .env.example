DATABASE_URL="postgresql://<username>:<password>@<host>/<database>?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://<username>:<password>@<host>/<database>?sslmode=require&channel_binding=require"
NEXTAUTH_SECRET="<your-nextauth-secret>"
PGTZ=UTC

# SMTP Mail Ayarları (Kurumsal E-posta)
SMTP_HOST="<smtp-host>"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="<smtp-user>"
SMTP_PASS="<smtp-pass>"
SMTP_FROM="SoleCost <admin@example.com>"

# Alternatif: Gmail SMTP (Daha güvenilir)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-gmail@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="SoleCost <your-gmail@gmail.com>"

# Alternatif: SendGrid SMTP
# SENDGRID_API_KEY="your-sendgrid-api-key"
# SMTP_FROM="SoleCost <noreply@yourdomain.com>"
